{
  "name": "pi-extension-windsurf-provider",
  "version": "0.3.2",
  "description": "Pi extension that exposes Windsurf upstream as a custom SWE-1.6 provider.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "windsurf",
    "provider",
    "swe"
  ],
  "license": "MIT",
  "type": "module",
  "files": [
    "index.ts",
    "README.md",
    "LICENSE",
    "src",
    "bin",
    "scripts"
  ],
  "bin": {
    "pi-windsurf-account": "./bin/pi-windsurf-account.mjs"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test:context": "node scripts/check-context-request.mjs",
    "smoke:list-models": "pi -e . --list-models windsurf",
    "smoke:account-cli": "node bin/pi-windsurf-account.mjs where"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.67.68",
    "@mariozechner/pi-coding-agent": "^0.67.68",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.3"
  }
}
