{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "ignoreDeprecations": "6.0",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "lib": ["ES2024", "DOM", "DOM.Iterable"]
  },
  "include": ["index.ts", "src/**/*.ts"]
}
